# Copy this to .outreach.env (gitignored) and fill in. Used only by scripts/outreach-send.mjs.
# Gmail address you send FROM (replies come back here):
GMAIL_USER=asatianant2678@gmail.com
# 16-char Google App Password (NOT your normal password):
#   Google Account → Security → 2-Step Verification (must be ON) → App passwords → generate one.
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
# Where TEST sends go:
TEST_TO=coder2675@gmail.com
# Display name on the From line:
FROM_NAME=Anant
# Gap between LIVE sends in ms (45000 = 45s; ~34 min for 45 emails):
SEND_DELAY_MS=45000
